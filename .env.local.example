# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in the real values.
#   cp .env.local.example .env.local
# ----------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key. SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified sender/domain in Resend.
RESEND_FROM_EMAIL=Field Day Tracker <alerts@yourdomain.com>
# Where automated alerts are sent (the "dummy" recipient).
NOTIFY_EMAIL=ops@yourdomain.com

# --- Gemini (AI auto-fill: receipt scan, product link, tracking) ------------
# Get a key at https://aistudio.google.com. Server-only.
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# --- AfterShip (OPTIONAL — paid) --------------------------------------------
# NOT required. The app detects carriers for free (from the tracking number
# format) and gives clickable tracking links. Only set these if you separately
# want AfterShip's automatic "Shipped/Delivered" webhook updates.
# AFTERSHIP_API_KEY=your-aftership-api-key
# AFTERSHIP_WEBHOOK_SECRET=your-aftership-webhook-secret

# --- Google Sheets sync -----------------------------------------------------
# Service-account email + private key (from the downloaded JSON credentials).
GOOGLE_SERVICE_ACCOUNT_EMAIL=sheets-sync@your-project.iam.gserviceaccount.com
# Paste the full key. Keep the literal \n escapes or wrap the whole value in quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# The spreadsheet ID (from its URL) and the tab/range to append to.
GOOGLE_SHEET_ID=your-spreadsheet-id
GOOGLE_SHEET_RANGE=Master!A:H
