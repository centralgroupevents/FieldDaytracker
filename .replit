modules = ["nodejs-20"]

# Single Next.js server for dev — bind to all interfaces for Replit's webview.
run = "npm run dev -- -H 0.0.0.0 -p 3000"

[env]
NEXT_TELEMETRY_DISABLED = "1"

[[ports]]
localPort = 3000
externalPort = 80

# Production deployment (Publish -> Autoscale). next start reads $PORT.
[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start", "--", "-H", "0.0.0.0"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -- -H 0.0.0.0 -p 3000"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"
